   "source": [
    "import student_input # 전 PBL 에서 사용한 학생 정보 함수를 이용\n",
    "\n",
    "def save_students_txt(students):\n",
    "    with open(\"scores_korean.txt\", \"w\", encoding=\"utf-8\") as f:\n",
    "        for name, score in students.items():\n",
    "            f.write(f\"{name},{score}\\n\")"
   ]
